#!/bin/sh
# pre-commit — change-safety gate (enforcing by default).
# Set WARN_ONLY=1 to downgrade failures to warnings.

WARN_ONLY="${WARN_ONLY:-0}"
REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"

EXTRA_ARGS=""
if [ "$WARN_ONLY" = "1" ]; then
  EXTRA_ARGS="--warn-only"
fi

SCRIPTS=""
if [ -d "${REPO_ROOT}/scripts" ]; then
  SCRIPTS="${REPO_ROOT}/scripts"
elif [ -d "${REPO_ROOT}/.ai.biz/scripts" ]; then
  SCRIPTS="${REPO_ROOT}/.ai.biz/scripts"
else
  exit 0
fi

for check in touch-scope-verify blast-radius-check; do
  if [ -f "${SCRIPTS}/${check}.sh" ]; then
    if ! bash "${SCRIPTS}/${check}.sh" $EXTRA_ARGS; then
      MSG="  CHECK: ${SCRIPTS}/${check}.sh"
      if [ "$WARN_ONLY" = "1" ]; then
        echo "WARN: ${MSG}"
      else
        echo "FAIL: ${MSG}" >&2
        exit 1
      fi
    fi
  fi
done

exit 0
