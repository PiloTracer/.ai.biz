#!/bin/sh
# prepare-commit-msg — strip Co-authored-by trailers; auto-prepend task ref.

HOOKS_DIR="$(cd "$(dirname "$0")/.." && pwd)"
REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"

TMPFILE="${COMMIT_EDITMSG}.tmp"
grep -viE '^Co-authored-by:' "$1" > "$TMPFILE" && mv "$TMPFILE" "$1"

BRANCH="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
case "${2:-}" in
  message|commit|template)
    REF=""
    REF="$(echo "$BRANCH" | grep -oE '[A-Z]+-[0-9]+' | head -1)"
    if [ -z "$REF" ] && [ -f "${REPO_ROOT}/.work.biz/active-ref" ]; then
      REF="$(cat "${REPO_ROOT}/.work.biz/active-ref" | head -1)"
    fi
    if [ -n "$REF" ]; then
      FIRST="$(head -1 "$1")"
      case "$FIRST" in
        [A-Z]*-[0-9]*:*) ;;
        *) sed -i "1s/^/${REF}: /" "$1" ;;
      esac
    fi
    ;;
esac
